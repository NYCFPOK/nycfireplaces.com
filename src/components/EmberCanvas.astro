---
// Site-wide ambient ember particles — from the approved "Fire, Perfected"
// concept. Fixed canvas, screen-blended, fully disabled for reduced-motion.
// Pauses when the tab is hidden to save battery.
---

<canvas id="embers" aria-hidden="true"></canvas>

<style is:global>
  #embers {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    mix-blend-mode: screen;
  }
  @media (prefers-reduced-motion: reduce) {
    #embers {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var canvas = document.getElementById('embers');
    if (!canvas) return;
    var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    var ctx = canvas.getContext('2d');
    var W, H, embers = [], running = true, raf = null;

    function resize() { W = canvas.width = innerWidth; H = canvas.height = innerHeight; }
    addEventListener('resize', resize);
    resize();

    function spawn() {
      return {
        x: Math.random() * W,
        y: H + 10 + Math.random() * 60,
        r: 0.6 + Math.random() * 1.9,
        vy: 0.35 + Math.random() * 0.9,
        vx: (Math.random() - 0.5) * 0.3,
        sway: Math.random() * Math.PI * 2,
        swaySpd: 0.008 + Math.random() * 0.02,
        life: 0,
        maxLife: 380 + Math.random() * 300,
        hue: 22 + Math.random() * 18,
      };
    }

    for (var i = 0; i < 46; i++) {
      var e = spawn();
      e.y = Math.random() * H;
      e.life = Math.random() * e.maxLife * 0.5;
      embers.push(e);
    }

    function tick() {
      if (!running) return;
      ctx.clearRect(0, 0, W, H);
      for (var i = 0; i < embers.length; i++) {
        var e = embers[i];
        e.life++;
        e.sway += e.swaySpd;
        e.y -= e.vy;
        e.x += e.vx + Math.sin(e.sway) * 0.35;
        var fade = 1 - e.life / e.maxLife;
        if (fade <= 0 || e.y < -12) { embers[i] = spawn(); continue; }
        var flicker = 0.55 + 0.45 * Math.sin(e.life * 0.15 + e.sway * 3);
        ctx.beginPath();
        ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
        ctx.fillStyle = 'hsla(' + e.hue + ',100%,' + (58 + flicker * 12) + '%,' + (0.5 * fade * flicker).toFixed(3) + ')';
        ctx.shadowColor = 'hsla(' + e.hue + ',100%,55%,' + 0.8 * fade + ')';
        ctx.shadowBlur = 8;
        ctx.fill();
      }
      ctx.shadowBlur = 0;
      raf = requestAnimationFrame(tick);
    }

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        running = false;
        if (raf) cancelAnimationFrame(raf);
      } else {
        running = true;
        tick();
      }
    });

    tick();
  })();
</script>
