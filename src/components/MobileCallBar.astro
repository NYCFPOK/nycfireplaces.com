---
// Sticky mobile action bar — reinforces the conversion priority on phones,
// where click-to-call matters most. Hidden on lg+ screens.
import { business, mapsUrl } from '../data/business';
const primary = business.locations[0];
---

<div
  class="fixed inset-x-0 bottom-0 z-50 lg:hidden border-t border-stone-400/20 bg-coal-950/95 backdrop-blur-md"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <div class="grid grid-cols-4">
    <!-- Call = 2 columns (primary, biggest tap target) -->
    <a
      href={`tel:${primary.phone}`}
      data-cta="call"
      class="col-span-2 flex items-center justify-center gap-2 bg-ember-600 py-4 text-sm font-bold uppercase tracking-wide text-coal-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-stone-100"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
        <path d="M6.6 10.8a15.9 15.9 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1l-2.24 2.2Z" />
      </svg>
      Call Now
    </a>
    <a
      href={mapsUrl(primary.mapQuery)}
      target="_blank"
      rel="noopener"
      class="flex flex-col items-center justify-center gap-0.5 py-3 text-[0.65rem] font-semibold uppercase tracking-wide text-stone-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-ember-400"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5Z"/></svg>
      Showroom
    </a>
    <a
      href="/consultation"
      class="flex flex-col items-center justify-center gap-0.5 py-3 text-[0.65rem] font-semibold uppercase tracking-wide text-stone-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-ember-400"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M4 4h16a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Zm2 4v2h12V8H6Zm0 4v2h8v-2H6Z"/></svg>
      Get Quote
    </a>
  </div>
</div>
<!-- Spacer so fixed bar never covers footer content on mobile -->
<div aria-hidden="true" class="h-16 lg:hidden"></div>
