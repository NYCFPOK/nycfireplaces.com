---
import Base from '../layouts/Base.astro';
import ConversionBlock from '../components/ConversionBlock.astro';
import HeroFire from '../components/scenes/HeroFire.astro';
import { business } from '../data/business';

const CDN = 'https://www.nycfireplaces.com/wp-content/uploads';

// Homepage follows plan §11.3 section order. Copy uses ONLY approved facts
// (§4.5 / §11.4). Imagery is the client's own project photography.

// §11.4 proof strip — qualified wording only
const proof = [
  'Family-owned',
  '30+ years of team experience',
  '300+ five-star Google reviews',
  'Two showrooms — Queens & Long Island',
  'In-house, factory-trained install team',
];

// §11.3 fireplace + outdoor-kitchen decision paths
const paths = [
  {
    title: 'Fireplaces',
    copy: 'Gas, electric, wood, water-vapor and ethanol — fireboxes, inserts, stoves, mantels and media walls, designed and installed by our own team.',
    img: `${CDN}/2022/08/Kozy-Heat-fireplace-1.jpg`,
    href: '/fireplaces',
    cta: 'Explore fireplaces',
    fx: 'flames embers',
    rect: '22,40,56,42', // firebox region of the Kozy Heat photo
    intensity: 'high',
  },
  {
    title: 'Outdoor Kitchens',
    copy: 'Custom islands, built-in grills, power burners, pizza ovens and stainless cabinetry — from a free 3D design to a finished build.',
    img: `${CDN}/2022/08/stoll-custom-bbq-island.jpg`,
    href: '/outdoor-kitchen',
    cta: 'Explore outdoor kitchens',
    fx: 'kenburns', // no visible flame in this photo
    rect: '',
    intensity: 'med',
  },
];

// §11.3 "Add a fireplace to almost any home" — fuel/type routes
const fireplaceTypes = [
  { label: 'Gas & propane', href: '/fireplaces' },
  { label: 'Electric', href: '/fireplaces' },
  { label: 'Water-vapor', href: '/fireplaces' },
  { label: 'Wood-burning', href: '/fireplaces' },
  { label: 'Inserts', href: '/fireplaces' },
  { label: 'Stoves', href: '/stoves' },
];

// §11.3 selected projects — real project imagery (Portfolio teaser)
const projects = [
  { img: `${CDN}/2022/07/nyc-fireplaces-custom-install.jpg`, label: 'Custom fireplace install', fx: 'flames', rect: '3,62,52,7', intensity: 'med' },
  { img: `${CDN}/2022/08/stoll-custom-bbq-island.jpg`, label: 'Custom BBQ island', fx: '', rect: '', intensity: 'med' },
  { img: `${CDN}/2022/08/American-Fyre-Design-Fire-Table.jpg`, label: 'Fire feature', fx: 'flames embers', rect: '30,40,40,18', intensity: 'med' },
  { img: `${CDN}/2022/08/Twin-Eagles-Grill.jpg`, label: 'Built-in grill', fx: '', rect: '', intensity: 'med' },
];

const brands = [
  'Alfa Forni', 'Modern Flames', 'Kozy Heat', 'Danver', 'Hestan',
  'Twin Eagles', 'American Fyre', 'Gozney', 'Napoleon', 'Delta Heat',
];

const steps = [
  { n: '01', title: 'Consultation', copy: 'We learn your space, your style and how you live — in our showroom or on-site.' },
  { n: '02', title: 'Design', copy: 'Our in-house designers craft a build tailored to your home, with real product and material selections.' },
  { n: '03', title: 'Installation', copy: 'Our own factory-trained team installs it — not generic subcontracted crews.' },
];

// §11.3 helpful guides — real published articles
const guides = [
  { title: '3 Reasons Adding a Fireplace Can Increase Your Home’s Value', href: '/3-reasons-why-adding-a-fireplace-can-increase-your-homes-value' },
  { title: 'Build an Outdoor Bar: Expert Design & Construction Tips', href: '/build-an-outdoor-bar' },
  { title: 'Trends to Expand Your Outdoor Living Space', href: '/trends-to-expand-your-outdoor-living-space' },
];
---

<Base
  title="Fireplaces & Outdoor Kitchens in NYC & Long Island"
  description={business.description}
  path="/"
>
  <!-- 1 — HERO: illustrated "Fire, Perfected" scene with live flames -->
  <HeroFire />

  <!-- 2 — PROOF STRIP (§11.4, approved wording) -->
  <section class="border-y border-gold-500/20 bg-coal-900">
    <div class="container-page py-7">
      <ul class="flex flex-wrap items-center justify-center gap-x-9 gap-y-3 text-[0.78rem] font-semibold uppercase tracking-[0.16em] text-stone-300">
        {proof.map((p, i) => (
          <li class="flex items-center gap-9">
            {i > 0 && <span aria-hidden="true" class="hidden text-[0.5rem] text-gold-400 sm:inline">◆</span>}
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 3 — DECISION PATHS -->
  <section class="section-light">
    <div class="container-page py-20">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow mb-4">Where would you like to begin?</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl">Two ways we bring <span class="display-accent">fire</span> to your home</h2>
      </div>
      <div class="mt-12 grid gap-7 md:grid-cols-2" data-reveal data-reveal-group>
        {paths.map((p) => (
          <a href={p.href} class="card-luxe group block">
            <div class="aspect-[16/11] overflow-hidden">
              <img
                src={p.img}
                alt={p.title}
                class="h-full w-full object-cover"
                data-fx={p.fx || undefined}
                data-flame-rect={p.rect || undefined}
                data-flame-intensity={p.intensity}
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-coal-950/92 via-coal-950/25 to-transparent"></div>
            <div class="absolute bottom-0 p-8">
              <h3 class="text-3xl text-stone-100 md:text-4xl">{p.title}</h3>
              <p class="mt-2.5 max-w-md text-sm leading-relaxed text-stone-200">{p.copy}</p>
              <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-gold-300 transition-transform duration-500 group-hover:translate-x-1.5">
                {p.cta} <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4 — ADD A FIREPLACE TO ALMOST ANY HOME -->
  <section class="section-cream">
    <div class="container-page grid gap-12 py-24 lg:grid-cols-[1fr_1.1fr] lg:items-center">
      <div data-reveal>
        <p class="eyebrow mb-4">For almost any room</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl">Add a fireplace to <span class="display-accent">almost any home</span></h2>
        <p class="mt-5 max-w-lg text-coal-700">
          Chimney or no chimney, co-op or single-family — modern venting and electric, water-vapor
          and ethanol options make it possible to add a fireplace to rooms that never had one.
          We help you choose what actually fits your space and approvals.
        </p>
        <div class="mt-7 flex flex-wrap gap-2.5">
          {fireplaceTypes.map((t) => (
            <a href={t.href} class="rounded-full border border-coal-900/20 px-4 py-2 text-sm font-medium text-coal-800 transition-colors hover:border-ember-600 hover:text-ember-600">
              {t.label}
            </a>
          ))}
        </div>
      </div>
      <figure class="card-luxe" data-reveal>
        <img
          src={`${CDN}/2022/07/nyc-fireplaces-custom-install.jpg`}
          alt="A linear gas fireplace installation in a New York home"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
          data-fx="flames embers"
          data-flame-rect="3,62,52,7"
          data-flame-intensity="high"
        />
      </figure>
    </div>
  </section>

  <!-- 5 — OUTDOOR KITCHEN DESIGN/BUILD + FREE 3D -->
  <section class="relative overflow-hidden">
    <img src={`${CDN}/2022/08/stoll-custom-bbq-island.jpg`} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-r from-coal-950/92 via-coal-950/80 to-coal-950/60"></div>
    <div class="container-page relative py-28">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow mb-3">Designed, supplied, built &amp; installed</p>
        <h2 class="text-4xl md:text-5xl">Outdoor kitchens, from a free 3D design</h2>
        <p class="mt-5 text-stone-300">
          See your outdoor kitchen before it’s built. With a qualifying purchase, our designers
          produce a free 3D design — grills, power burners, pizza ovens, refrigeration and stainless
          cabinetry — then our team builds and installs it.
        </p>
        <div class="mt-7 flex flex-wrap gap-4">
          <a href="/free-3d-outdoor-kitchen-design" class="btn btn-primary">Get a Free 3D Design</a>
          <a href="/outdoor-kitchen" class="btn btn-ghost">Explore outdoor kitchens</a>
        </div>
        <p class="mt-4 text-xs text-stone-400">Free 3D outdoor-kitchen design with qualifying purchase.</p>
      </div>
    </div>
  </section>

  <!-- 6 — SELECTED PROJECTS -->
  <section class="section-light">
    <div class="container-page py-20">
      <div class="mb-12 flex flex-wrap items-end justify-between gap-4" data-reveal>
        <div>
          <p class="eyebrow mb-4">Recent work</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl">Selected <span class="display-accent">projects</span></h2>
        </div>
        <a href="/installations" class="btn btn-ghost !border-coal-900/30 !text-coal-800 hover:!border-ember-600 hover:!text-ember-600">View the portfolio</a>
      </div>
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4" data-reveal data-reveal-group>
        {projects.map((p) => (
          <figure class="card-luxe group">
            <img
              src={p.img}
              alt={p.label}
              class="aspect-[4/5] w-full object-cover"
              loading="lazy"
              data-fx={p.fx || undefined}
              data-flame-rect={p.rect || undefined}
              data-flame-intensity={p.fx ? p.intensity : undefined}
            />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-coal-950/90 to-transparent p-4 text-xs font-medium uppercase tracking-wider text-stone-100">{p.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- 7 — SHOWROOM EXPERIENCE + 8 BRANDS -->
  <section class="section-cream">
    <div class="container-page py-20">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow mb-4">See it, feel the heat, plan it</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl">The <span class="display-accent">showroom</span> experience</h2>
        <p class="mt-5 text-coal-700">
          Live displays let you compare flames, finishes and sizes in person — and plan your project
          with a specialist. Two showrooms serve the metro area: Queens and Long Island.
        </p>
        <a href="/locations" class="mt-6 inline-block btn btn-primary">See It in a Showroom</a>
      </div>
      <div class="mt-12 border-t border-coal-900/15 pt-10">
        <p class="mb-6 text-sm font-semibold uppercase tracking-wider text-coal-700">Trusted brands, expertly installed</p>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-4">
          {brands.map((b) => (
            <span class="font-[var(--font-display)] text-2xl text-coal-900/55 transition-colors hover:text-coal-900">{b}</span>
          ))}
          <a href="/brands" class="text-sm font-semibold text-ember-600 hover:text-ember-500">All brands →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 9 — PROCESS -->
  <section class="border-y border-stone-400/15 bg-coal-900">
    <div class="container-page py-24">
      <div data-reveal>
        <p class="eyebrow mb-4">How it works</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl">From idea to installed — <span class="display-accent">without the handoffs</span></h2>
      </div>
      <div class="mt-14 grid gap-10 md:grid-cols-3" data-reveal data-reveal-group>
        {steps.map((s) => (
          <div class="relative border-t border-gold-500/25 pt-6">
            <div class="font-[var(--font-display)] text-6xl text-gold-400/90">{s.n}</div>
            <h3 class="mt-4 text-2xl">{s.title}</h3>
            <p class="mt-3 text-stone-300 leading-relaxed">{s.copy}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 10 — FINANCING -->
  <section class="section-light">
    <div class="container-page py-16" data-reveal>
      <div class="flex flex-col items-start gap-7 rounded-sm border border-gold-500/30 bg-stone-200/60 px-8 py-10 shadow-[var(--shadow-card)] sm:flex-row sm:items-center sm:justify-between md:px-12">
        <div>
          <p class="eyebrow mb-3">Make it comfortable</p>
          <h2 class="text-3xl md:text-4xl">Financing available through <span class="display-accent">Acorn Finance</span></h2>
          <p class="mt-3 max-w-xl text-coal-700">Explore monthly-payment options for your fireplace or outdoor-kitchen project.</p>
        </div>
        <a href="/financing" class="btn btn-primary shrink-0">Explore financing</a>
      </div>
    </div>
  </section>

  <!-- 11 — TRADE PROFESSIONALS -->
  <section class="section-cream">
    <div class="container-page grid gap-10 py-20 lg:grid-cols-[1.1fr_1fr] lg:items-center">
      <figure class="card-luxe" data-reveal>
        <img src={`${CDN}/2022/08/Twin-Eagles-Grill.jpg`} alt="Built-in grill installation for a trade project" class="aspect-[16/10] w-full object-cover" loading="lazy" />
      </figure>
      <div data-reveal>
        <p class="eyebrow mb-4">For the trade</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl">Builders, architects &amp; <span class="display-accent">designers</span></h2>
        <p class="mt-5 max-w-lg text-coal-700">
          Plan review, product specifications, rough-opening and venting coordination, submittals,
          and supply-only or supply-and-install options — with a dedicated point of contact for
          your projects.
        </p>
        <a href="/builders-architects" class="mt-6 inline-block btn btn-primary">Work with our trade team</a>
      </div>
    </div>
  </section>

  <!-- 12 — REVIEWS (§16.3 static, §4.11 no fabricated quotes) -->
  <section class="section-light">
    <div class="container-page py-20 text-center" data-reveal>
      <div class="flex items-center justify-center gap-1 text-ember-500" aria-hidden="true">
        {[0, 1, 2, 3, 4].map(() => (
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current"><path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.4 21.7l1.8-7.3L1.5 9.5 9 8.9 12 2Z"/></svg>
        ))}
      </div>
      <p class="mt-4 font-[var(--font-display)] text-3xl md:text-4xl text-coal-900">More than 300 five-star Google reviews</p>
      <p class="mx-auto mt-3 max-w-xl text-coal-700">Homeowners, builders and designers across the New York metro area trust our in-house team.</p>
      <a href="https://www.google.com/search?q=NYC+Fireplaces+%26+Outdoor+Kitchens+reviews" target="_blank" rel="noopener" class="mt-6 inline-block btn btn-primary">Read our Google reviews</a>
    </div>
  </section>

  <!-- 13 + 14 — TWO-SHOWROOM BLOCK + FINAL CTA -->
  <ConversionBlock />

  <!-- 15 — HELPFUL GUIDES -->
  <section class="section-cream">
    <div class="container-page py-20">
      <div class="mb-12 flex flex-wrap items-end justify-between gap-4" data-reveal>
        <div>
          <p class="eyebrow mb-4">Plan with confidence</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl">Helpful <span class="display-accent">guides</span></h2>
        </div>
        <a href="/blogs" class="link-underline text-sm font-semibold uppercase tracking-wider text-ember-600">All guides &amp; articles →</a>
      </div>
      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-group>
        {guides.map((g) => (
          <a href={g.href} class="group flex flex-col justify-between rounded-sm border border-coal-900/12 bg-stone-100 p-8 shadow-[var(--shadow-card)] transition-all duration-500 hover:-translate-y-1 hover:border-ember-600/40 hover:shadow-[var(--shadow-luxe)]">
            <h3 class="text-xl leading-snug text-coal-900">{g.title}</h3>
            <span class="mt-6 inline-block text-sm font-semibold uppercase tracking-wider text-ember-600 transition-transform duration-500 group-hover:translate-x-1.5">Read the guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
